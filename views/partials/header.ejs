<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= locals.title || 'PILLMATE' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<header class="app-topbar">
  <div class="topbar-left">
    <img src="/images/icons/<%= locals.pageIcon || 'home' %>.svg" alt="현재 페이지" class="topbar-page-icon">
    <span class="topbar-title"><%= locals.pageTitle || '홈' %></span>
    <span class="topbar-user">ooo님, 안녕하세요</span>
  </div>
  <button class="notification-btn" type="button">
    <img src="/images/icons/notification.svg" alt="알림" class="topbar-bell-icon">
  </button>
</header>
